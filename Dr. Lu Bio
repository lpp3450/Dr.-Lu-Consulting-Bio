<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STRUCTURES110 – Heightened Research | Dr. Lu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --slate-dark: #2c3e50;
            --slate: #3d5a73;
            --slate-light: #4a6d8a;
            --gold: #c9a227;
            --gold-light: #d4b342;
            --cream: #f8f6f1;
            --white: #ffffff;
            --charcoal: #1a1a1a;
            --text-muted: #a8b8c8;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--charcoal);
            color: var(--cream);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* Hero Section */
        .hero {
            background: var(--charcoal);
            padding: 5rem 2rem;
            text-align: center;
        }

        .hero-logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            color: var(--gold);
            margin-bottom: 0.5rem;
        }

        .hero-logo span {
            color: var(--white);
        }

        .hero-tagline {
            font-size: 0.75rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 3rem;
        }

        .hero h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 500;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            color: var(--white);
        }

        .hero h1 .accent {
            color: var(--gold);
            font-style: italic;
        }

        .hero-description {
            font-size: 1.15rem;
            color: var(--text-muted);
            margin-bottom: 3rem;
            max-width: 620px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.8;
        }

        /* Contact Buttons */
        .contact-buttons {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            max-width: 420px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .contact-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            padding: 1.4rem 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Outfit', sans-serif;
        }

        .contact-btn-call {
            background: var(--gold);
            color: var(--charcoal);
            border: 2px solid var(--gold);
        }

        .contact-btn-call:hover {
            background: var(--gold-light);
            border-color: var(--gold-light);
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(201, 162, 39, 0.3);
        }

        .contact-btn-email {
            background: transparent;
            color: var(--cream);
            border: 2px solid var(--slate-light);
        }

        .contact-btn-email:hover {
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-3px);
        }

        .contact-btn svg {
            width: 24px;
            height: 24px;
            flex-shrink: 0;
        }

        /* Divider */
        .divider {
            width: 100%;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--slate), transparent);
        }

        /* About Section */
        .about {
            padding: 5rem 2rem;
            background: var(--slate-dark);
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-label {
            font-size: 0.7rem;
            letter-spacing: 0.4em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1rem;
        }

        .section-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.8rem, 4vw, 2.5rem);
            font-weight: 500;
            color: var(--white);
        }

        .about-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .about-text h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-weight: 500;
            margin-bottom: 1.5rem;
            color: var(--gold);
        }

        .about-text p {
            color: var(--text-muted);
            margin-bottom: 1.5rem;
            font-size: 1rem;
            line-height: 1.8;
        }

        .credentials {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .credential-item {
            padding: 1.25rem;
            background: rgba(61, 90, 115, 0.3);
            border-left: 3px solid var(--gold);
            transition: all 0.3s ease;
        }

        .credential-item:hover {
            background: rgba(61, 90, 115, 0.5);
            transform: translateX(5px);
        }

        .credential-item h4 {
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 0.4rem;
        }

        .credential-item p {
            color: var(--cream);
            font-size: 0.95rem;
        }

        /* Services Section */
        .services {
            padding: 5rem 2rem;
            background: var(--charcoal);
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .service-card {
            padding: 2rem;
            background: rgba(61, 90, 115, 0.15);
            border: 1px solid rgba(61, 90, 115, 0.3);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--gold);
            transform: translateX(-100%);
            transition: transform 0.4s ease;
        }

        .service-card:hover::before {
            transform: translateX(0);
        }

        .service-card:hover {
            transform: translateY(-5px);
            border-color: var(--slate);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
        }

        .service-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .service-card h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            margin-bottom: 0.75rem;
            color: var(--cream);
        }

        .service-card p {
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.7;
        }

        /* Bottom Contact Section */
        .contact-bottom {
            padding: 5rem 2rem;
            background: var(--slate-dark);
            text-align: center;
        }

        .contact-bottom h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            margin-bottom: 1rem;
            color: var(--white);
        }

        .contact-bottom p {
            color: var(--text-muted);
            margin-bottom: 2.5rem;
            font-size: 1.05rem;
        }

        .contact-bottom .contact-buttons {
            max-width: 380px;
        }

        /* Footer */
        footer {
            padding: 2rem;
            background: var(--charcoal);
            text-align: center;
            border-top: 1px solid var(--slate-dark);
        }

        .footer-logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            color: var(--gold);
            letter-spacing: 0.15em;
            margin-bottom: 0.5rem;
        }

        .footer-text {
            color: var(--text-muted);
            font-size: 0.8rem;
        }

        .footer-text em {
            font-style: normal;
            color: var(--gold);
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .about-content {
                grid-template-columns: 1fr;
                gap: 3rem;
            }

            .services-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .hero {
                padding: 4rem 1.5rem;
            }

            .hero h1 {
                font-size: 1.8rem;
            }

            .contact-btn {
                padding: 1.2rem 1.5rem;
                font-size: 1rem;
            }

            .about, .services, .contact-bottom {
                padding: 3.5rem 1.5rem;
            }
        }
    </style>
</head>
